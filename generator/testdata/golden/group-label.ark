# Group labels reserve a strip so the label never overlaps the children. The
# strip is at the top by default; `label: bottom` moves it under the children.
# In a bordered group it acts as an inner wall (the children's facing margin
# lands against it); a box:none group reserves the same strip but packs its
# children flush below it (it draws no border and adds no perimeter).
topLabel {
  label: "Top Group"

  a { label: "A" }
  b { label: "B" }
}

bottomLabel {
  label: "Bottom Group"

  c { label: "C" }
  d { label: "D" }
}

borderless {
  label: "Borderless"

  e { label: "E" }
  f { label: "F" }
}

@layout {
  topLabel    { direction: vertical }
  bottomLabel { direction: vertical; label: bottom }
  borderless  { direction: vertical; box: none }
}
