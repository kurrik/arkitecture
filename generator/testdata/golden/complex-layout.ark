# Complex layout with nested containers and arrows
root {
  frontend {
    label: "Frontend"

    react {
      label: "React App"
    }
    assets {
      label: "Static Assets"
    }
  }

  backend {
    label: "Backend Services"

    api {
      label: "REST API"
    }
    auth {
      label: "Auth Service"
    }
  }

  database {
    label: "Database"
  }
}

# Presentation lives in the layout layer.
@layout {
  root         { direction: horizontal }
  root.backend { direction: vertical }
}

# Arrows showing data flow
root.frontend.react --> root.backend.api
root.backend.api --> root.database
root.backend.auth --> root.database
