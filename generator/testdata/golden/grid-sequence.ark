# A conventional sequence diagram on the grid arrangement: 3 fixed columns
# (participants), rows grow with time. One row per message; the labelled sender
# and an invisible receiver share that row so the arrow is horizontal. Lanes a
# message skips carry no cell — sparse placement, no alignment placeholders.
seq {
  hC{label:"Client"} hS{label:"Server"} hD{label:"Database"}
  m1s{label:"login()"} m1t{kind:invisible}
  m2s{label:"SELECT"}  m2t{kind:invisible}
  m3s{label:"rows"}    m3t{kind:invisible}
  m4s{label:"200 OK"}  m4t{kind:invisible}
}

@layout {
  margin: 14
  seq { box: none; cols: 3 }

  seq.hC {col:1; row:1}  seq.hS {col:2; row:1}  seq.hD {col:3; row:1}
  seq.m1s {col:1; row:2}  seq.m1t {col:2; row:2}
  seq.m2s {col:2; row:3}  seq.m2t {col:3; row:3}
  seq.m3s {col:3; row:4}  seq.m3t {col:2; row:4}
  seq.m4s {col:2; row:5}  seq.m4t {col:1; row:5}

  seq.m3s { pathColor: #2563eb }
  seq.m4s { pathColor: #2563eb }
}

seq.m1s --> seq.m1t
seq.m2s --> seq.m2t
seq.m3s --> seq.m3t
seq.m4s --> seq.m4t
