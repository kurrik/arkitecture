# route: orthogonal routes arrows attached to explicit anchors, too. An anchor on
# a box edge leaves/enters perpendicular to *that* edge: Source's out anchor is on
# the bottom, so the line drops straight down before turning toward the target. An
# interior anchor (Service's core) is reached by routing to the facing border and
# then entering the node.
source {
  label: "Source"
  anchors: [out]
}
service {
  label: "Service"
  api { label: "API" }
  db  { label: "DB" }
  anchors: [core]
}

@layout {
  route: orthogonal
  margin: 24
  source  { anchor out: [0.5, 1.0] }   # bottom-centre of Source: an edge anchor
  service {
    direction: vertical
    anchor core: [0.5, 0.5]            # interior centre of Service: the line enters it
  }
}

source#out --> service#core
