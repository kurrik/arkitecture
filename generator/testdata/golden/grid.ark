# @grid mechanics: a colSpan title, explicit placement, an auto-placed cell
# filling the next free slot, and a justify override (start) inside a span.
g {
  title{label:"Grid demo"}
  a{label:"A"} b{label:"B"} c{label:"C"}
  wide{label:"spans two"}
  auto{label:"auto"}
}
@layout {
  margin: 8
  g { @grid { cols: 3 } }
  g.title {col:1; row:1; colSpan:3}
  g.a {col:1; row:2}  g.b {col:2; row:2}  g.c {col:3; row:2}
  g.wide {col:1; row:3; colSpan:2; justify: start}
  g.auto {row:3}
}
